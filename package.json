{
  "name": "ts-dao-aston",
  "version": "0.1.0",
  "description": "Lightweight PostgreSQL DAO library for Node.js + TypeScript",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run --exclude 'test/**'",
    "test:watch": "vitest --exclude 'test/**'",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:all": "npm test && docker compose up -d --wait && npm run test:integration; docker compose down",
    "test:coverage": "docker compose up -d --wait && vitest run --config vitest.coverage.config.ts; docker compose down",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "postgresql",
    "dao",
    "typescript",
    "named-parameters",
    "zod"
  ],
  "license": "MIT",
  "peerDependencies": {
    "pg": ">=8.0.0",
    "zod": ">=3.0.0"
  },
  "devDependencies": {
    "@types/pg": "^8.11.0",
    "@vitest/coverage-v8": "^3.2.4",
    "pg": "^8.13.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "zod": "^3.24.0"
  }
}
