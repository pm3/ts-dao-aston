{
  "name": "ts-dao-aston",
  "version": "0.1.0",
  "description": "Lightweight PostgreSQL DAO library for Node.js + TypeScript",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "postgresql",
    "dao",
    "typescript",
    "named-parameters",
    "zod"
  ],
  "license": "MIT",
  "peerDependencies": {
    "pg": ">=8.0.0",
    "zod": ">=3.0.0"
  },
  "devDependencies": {
    "@types/pg": "^8.11.0",
    "pg": "^8.13.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "zod": "^3.24.0"
  }
}
